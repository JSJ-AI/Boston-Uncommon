+// ── 911 CALL INCIDENT GENERATOR (Phase 1) ────────────────────────────────────
+// Auto-generates a random incident from a curated table on button click.
+// Spawns a BadGuy of the appropriate type at a random map point, fills the
+// 911 call display panel with a templated script, and reads it aloud via TTS.
+
+var INCIDENT_TYPES = [
+  { id:'hit_run',     label:'Hit and run',                  objType:'car',    weight:3,
+    template:"Hello, yes, I need to report a hit and run. A {color} sedan just sideswiped a vehicle near {address}. They're heading {direction}. Please send someone." },
+  { id:'carjack',     label:'Carjacking in progress',       objType:'car',    weight:1,
+    template:"Nine-one-one, there's a carjacking happening near {address}. The suspect took off in a {color} car going {direction}." },
+  { id:'sus_vehicle', label:'Suspicious vehicle',           objType:'car',    weight:2,
+    template:"There's a {color} car parked near {address} that's been there a while with someone inside. Looks suspicious." },
+  { id:'bike_snatch', label:'Bike snatcher',                objType:'bike',   weight:2,
+    template:"A guy on a {color} bicycle just grabbed a purse and took off heading {direction} near {address}. Wearing a dark hoodie." },
+  { id:'foot_robber', label:'Robbery suspect on foot',      objType:'person', weight:2,
+    template:"Someone in a {color} shirt just robbed a passerby and is running {direction} on {street}. Please hurry." },
+  { id:'youth_group', label:'Group of youths',              objType:'person', weight:2, subkind:'group',
+    template:"There's a group of maybe three kids causing a disturbance near {landmark}. Wearing mostly {color}. They're being loud and harassing people." },
+  { id:'distress',    label:'Person in distress',           objType:'person', weight:2, motion:'still',
+    template:"There's a person in a {color} shirt down on the ground near {landmark}. They're not moving much. I think they need help." },
+  { id:'shots_fired', label:'Shots fired',                  objType:'person', weight:1, subkind:'gunshot', motion:'still',
+    template:"I just heard three or four gunshots from somewhere near {landmark}. I see someone in a {color} jacket but they're not moving — I think they're hurt." }
+];
+
+var CAR_COLORS   = [['white',25],['black',22],['gray',18],['silver',12],['red',9],['blue',8],['green',3],['gold',3]];
+var SHIRT_COLORS = [['blue',18],['black',18],['white',15],['gray',12],['red',10],['green',8],['yellow',5],['orange',5],['brown',5],['purple',4]];
+var BIKE_COLORS  = [['black',30],['silver',15],['blue',15],['red',12],['white',10],['green',8],['yellow',5],['orange',5]];
+
+var BOSTON_STREETS   = ['Boylston Street','Tremont Street','Charles Street','Beacon Street','Park Street','Arlington Street','Berkeley Street','Clarendon Street','Newbury Street','Commonwealth Avenue','Stuart Street','Washington Street'];
+var BOSTON_LANDMARKS = ['the Frog Pond','the Park Street T entrance','the Public Garden','the State House','the Common bandstand','the Brewer Fountain','the Boylston T entrance','Government Center','the Soldiers Monument','Beacon Hill'];
+var DIRECTIONS       = ['north','south','east','west','northbound on Tremont','southbound on Charles','eastbound on Boylston','westbound on Beacon','toward Government Center','toward the Common'];
+
+function _ic_wpick(arr) {
+  var t = 0; for (var i=0;i<arr.length;i++) t += arr[i][1];
+  var r = Math.random() * t;
+  for (var j=0;j<arr.length;j++) { r -= arr[j][1]; if (r <= 0) return arr[j][0]; }
+  return arr[0][0];
+}
+function _ic_pick(arr) { return arr[Math.floor(Math.random()*arr.length)]; }
+
+function _ic_colorFor(objType) {
+  if (objType === 'car')  return _ic_wpick(CAR_COLORS);
+  if (objType === 'bike') return _ic_wpick(BIKE_COLORS);
+  return _ic_wpick(SHIRT_COLORS);
+}
+
+function _ic_randomMapPoint() {
+  // Interior of operational area (BBOX 42.338,-71.090,42.373,-71.042)
+  var latMin = 42.345, latMax = 42.365;
+  var lngMin = -71.082, lngMax = -71.050;
+  return { lat: latMin + Math.random()*(latMax-latMin),
+           lng: lngMin + Math.random()*(lngMax-lngMin) };
+}
+
+function _ic_randomAddress() {
+  var num = 100 + Math.floor(Math.random() * 800);
+  return num + ' ' + _ic_pick(BOSTON_STREETS);
+}
+
+function _ic_fill(tpl, tokens) {
+  return tpl.replace(/\{(\w+)\}/g, function(_, k) {
+    return (tokens[k] != null) ? tokens[k] : ('{' + k + '}');
+  });
+}
+
+function _ic_pickIncident() {
+  var weighted = INCIDENT_TYPES.map(function(i) { return [i, i.weight || 1]; });
+  return _ic_wpick(weighted);
+}
+
+function _ic_speak(text) {
+  if (typeof window.speechSynthesis === 'undefined') return;
+  try {
+    window.speechSynthesis.cancel();
+    var voices = window.speechSynthesis.getVoices().filter(function(v) {
+      return v.lang && v.lang.toLowerCase().indexOf('en') === 0;
+    });
+    var utt = new SpeechSynthesisUtterance(text);
+    if (voices.length > 0) {
+      utt.voice = voices[Math.floor(Math.random()*voices.length)];
+    }
+    utt.rate  = 0.95 + Math.random()*0.1;
+    utt.pitch = 0.9  + Math.random()*0.2;
+    window.speechSynthesis.speak(utt);
+  } catch(e) { /* swallow */ }
+}
+
+function _ic_display(incident, text, tokens) {
+  var disp  = document.getElementById('call-display');
+  var label = document.getElementById('call-label');
+  var body  = document.getElementById('call-body');
+  var meta  = document.getElementById('call-meta');
+  if (!disp || !label || !body) return;
+  disp.style.display = 'block';
+  label.textContent = incident.label;
+  body.textContent  = '"' + text + '"';
+  if (meta) {
+    meta.textContent = 'Search criteria: ' + incident.objType + ' / ' + tokens.color;
+  }
+}
+
+function answer911Call() {
+  if (!scenarioOn) {
+    addAlert('warn', 'Start scenario before answering 911 calls.');
+    return;
+  }
+  var incident = _ic_pickIncident();
+  var tokens = {
+    color:     _ic_colorFor(incident.objType),
+    direction: _ic_pick(DIRECTIONS),
+    address:   _ic_randomAddress(),
+    street:    _ic_pick(BOSTON_STREETS),
+    landmark:  _ic_pick(BOSTON_LANDMARKS)
+  };
+  var callText = _ic_fill(incident.template, tokens);
+  var pt = _ic_randomMapPoint();
+
+  // Phase 1: single bad guy. Clear any existing one first.
+  if (typeof badGuy !== 'undefined' && badGuy) {
+    clearIncident();
+  }
+
+  // Place the bad guy — reuses existing plumbing (snap-to-road, timer, panel, feed)
+  placeBadGuy(pt.lat, pt.lng, incident.objType);
+
+  // Stash incident metadata onto the bad guy for downstream phases
+  if (typeof badGuy !== 'undefined' && badGuy) {
+    badGuy.incidentMeta = {
+      id:       incident.id,
+      label:    incident.label,
+      color:    tokens.color,
+      subkind:  incident.subkind || null,
+      motion:   incident.motion  || 'moving',
+      callText: callText
+    };
+    // If incident is "still" (distress, shots fired, suspicious vehicle), freeze motion
+    if (incident.motion === 'still') {
+      badGuy.maxSpeed = 0;
+    }
+  }
+
+  _ic_display(incident, callText, tokens);
+  _ic_speak(callText);
+}
+
+document.getElementById('btn-deploy').onclick = answer911Call;
 document.getElementById('btn-reset').onclick=function(){
   // Stop movement and clear agents
   stopMovement();
   removeAllAgents();
-  document.getElementById('tpicker').style.display='none';
+  var _cd = document.getElementById('call-display');
+  if (_cd) _cd.style.display='none';
   document.getElementById('i-type').textContent='None';
   document.getElementById('i-type').classList.add('none');
   document.getElementById('i-loc').textContent='--';
